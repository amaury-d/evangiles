---
import Passage from "./Passage.astro";

const { section, translations, defaultTranslation } = Astro.props;
const base = import.meta.env.BASE_URL;
const siteRoot = base.endsWith("/") ? base : `${base}/`;
const images = section.images ? Object.entries(section.images) : [];
---

<section class="harmony-section" id={section.id}>
  <header class="section-header">
    <h2>{section.title}</h2>
    {(section.date || section.lieu) && (
      <dl class="meta-list">
        {section.date && <><dt>Date</dt><dd>{section.date}</dd></>}
        {section.lieu && <><dt>Lieu</dt><dd>{section.lieu}</dd></>}
      </dl>
    )}
  </header>

  {images.map(([src, caption]) => (
    <figure class="figure">
      <img src={`${siteRoot}assets/${src}`} alt={caption} loading="lazy" />
      <figcaption>{caption}</figcaption>
    </figure>
  ))}

  {section.passages?.length > 0 && (
    <div class="passage-grid">
      {section.passages.map((passage) => (
        <Passage passage={passage} translations={translations} defaultTranslation={defaultTranslation} />
      ))}
    </div>
  )}

  {section.notes?.length > 0 && (
    <aside class="notes">
      <h3>Notes</h3>
      <ul>
        {section.notes.map((note) => <li set:html={note} />)}
      </ul>
    </aside>
  )}
</section>
