    <section class="annexe-page">
      <h1>Annexes</h1>
      <ul class="annexe-list">
        <li><a href={`${base}/annexes/apocryphes/`}>Apocryphes</a></li>
        <li><a href={`${base}/annexes/marc/`}>Marc</a></li>
        <li><a href={`${base}/annexes/bibliographie/`}>Bibliographie</a></li>
      </ul>
    </section>
  </SiteShell>
</BaseLayout>
