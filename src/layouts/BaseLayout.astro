---
import "../styles/main.css";

const { title, description = "Une harmonisation chronologique et annotée des Évangiles." } = Astro.props;
---

<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title} | Mon harmonie des Évangiles</title>
  </head>
  <body>
    <slot />
  </body>
</html>
